            "name": "total_quantity",
            "expr": "SUM(sold_quantity)",
            "displayName": "Total Quantity Sold"
          },
          {
            "name": "avg_order_value",
            "expr": "MEASURE(total_revenue) / MEASURE(count)",
            "displayName": "Average Order Value"
          }
        ]
      }
